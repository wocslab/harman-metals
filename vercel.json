{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",

  "redirects": [
    {
      "source": "/(.*)\\.html",
      "destination": "/$1",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/((?!sitemap.xml|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}